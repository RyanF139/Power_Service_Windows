# URL Server Backend Monitoring (Sesuaikan dengan IP/URL backend Anda)
BACKEND_URL=http://localhost:3001

# Token keamanan untuk autentikasi polling (Sesuai dengan WEBHOOK_TOKEN di backend)
AUTH_TOKEN=20181110008

# Metode identifikasi perangkat ('ip' atau 'mac')
IDENTIFY_BY=ip

# Nilai identifikasi perangkat (Jika kosong, script otomatis mendeteksi IP lokal)
IDENTIFY_VALUE=

# Interval pengecekan status (dalam detik)
POLL_INTERVAL_SECONDS=10
